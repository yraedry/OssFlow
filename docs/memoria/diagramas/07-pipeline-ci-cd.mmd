flowchart LR
    Dev[Desarrollador]
    PR[Pull Request]
    PushAny["Push a cualquier rama<br/>(push: branches: '**')"]
    PushMain["Push a main"]

    subgraph CI["W1 - Workflow CI (todas las ramas)"]
        Compile["mvn compile / npm ci"]
        Tests["mvn test (H2 in-memory)<br/>vitest"]
        Lint["Checkstyle / ESLint"]
        Coverage["JaCoCo umbral 75%"]
        GodFiles["Top 10 archivos largos"]
    end

    subgraph Release["W2 - Workflow Release (push: branches: '**')"]
        Build["Docker build multistage"]
        TagCalc["Tag = branch-slug + '-dev'<br/>main → 'main'"]
        Push2["Push a ghcr.io/yraedry/<br/>ossflow-backend:TAG<br/>ossflow-frontend:TAG"]
        OpenAPI["Publicar openapi.json<br/>en GitHub Release (solo main)"]
    end

    Deploy["docker compose pull + up -d<br/>en LXC (manual o webhook)"]

    Dev --> PR
    Dev --> PushAny
    Dev --> PushMain

    PR --> CI
    PushAny --> CI
    PushAny --> Release
    PushMain --> Release

    CI -->|verde| MergeOk[Merge permitido]
    CI -->|rojo| Block[Bloquea merge]

    Release --> Deploy

    classDef ok fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef bad fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    class MergeOk ok
    class Block bad
