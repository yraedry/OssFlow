{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["rulesets"],
  "properties": {
    "rulesets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["federationCode", "belt", "modality", "effectiveFrom"],
        "properties": {
          "federationCode": { "type": "string" },
          "belt":           { "enum": ["WHITE", "BLUE", "PURPLE", "BROWN", "BLACK"] },
          "modality":       { "enum": ["GI", "NOGI", "BOTH"] },
          "effectiveFrom":  { "type": "string", "format": "date" },
          "effectiveTo":    { "type": "string", "format": "date" },
          "sourceUrl":      { "type": "string" },
          "techniques": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["techniqueName", "status"],
              "properties": {
                "techniqueName":  { "type": "string" },
                "status":         { "enum": ["ALLOWED", "PROHIBITED", "CONDITIONAL"] },
                "conditionNotes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
